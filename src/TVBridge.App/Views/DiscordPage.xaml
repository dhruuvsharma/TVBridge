<UserControl x:Class="TVBridge.App.Views.DiscordPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="24" Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Discord" Style="{DynamicResource PageTitle}" Margin="0,0,0,4" />
            <TextBlock Text="Send signal notifications to Discord channels via webhooks" Style="{DynamicResource PageSubtitle}" />
        </StackPanel>

        <!-- Config + Test -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Webhook Config -->
            <Border Grid.Column="0" Style="{DynamicResource NeonCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Webhook Configuration" Style="{DynamicResource SectionTitle}" Margin="0,0,0,12" />

                    <TextBlock Text="Webhook URL" Style="{DynamicResource FieldLabel}" />
                    <TextBox Text="{Binding WebhookUrl, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource NeonTextBox}" Margin="0,0,0,12" />

                    <CheckBox Content="Channel Enabled" IsChecked="{Binding IsEnabled}"
                              Style="{DynamicResource NeonCheckBox}" Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save" Style="{DynamicResource NeonButtonPrimary}"
                                Margin="0,0,8,0" Command="{Binding SaveCommand}" />
                        <Button Content="Toggle Enable" Style="{DynamicResource NeonButton}"
                                Command="{Binding ToggleEnabledCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource NeonGreen}"
                               FontSize="11" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- Test -->
            <Border Grid.Column="1" Style="{DynamicResource NeonCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Test Connection" Style="{DynamicResource SectionTitle}" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Validate Config" Style="{DynamicResource NeonButton}"
                                Margin="0,0,8,0" Command="{Binding ValidateCommand}" />
                        <Button Content="Test Send (Dry Run)" Style="{DynamicResource NeonButton}"
                                Command="{Binding TestSendCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding TestResult}" Foreground="{DynamicResource NeonCyan}"
                               FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Setup Guide -->
        <Border Grid.Row="2" Style="{DynamicResource NeonCard}">
            <StackPanel>
                <TextBlock Text="Setup Guide" Style="{DynamicResource SectionTitle}" Margin="0,0,0,8" />
                <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="13" TextWrapping="Wrap" LineHeight="22">
                    <Run Text="1." FontWeight="Bold" Foreground="{DynamicResource NeonAmber}" />
                    <Run Text=" Go to Discord channel settings > Integrations > Webhooks" />
                    <LineBreak />
                    <Run Text="2." FontWeight="Bold" Foreground="{DynamicResource NeonAmber}" />
                    <Run Text=" Create a new webhook and copy its URL" />
                    <LineBreak />
                    <Run Text="3." FontWeight="Bold" Foreground="{DynamicResource NeonAmber}" />
                    <Run Text=" Paste the URL above and save" />
                    <LineBreak />
                    <Run Text="4." FontWeight="Bold" Foreground="{DynamicResource NeonAmber}" />
                    <Run Text=" Create routing rules in Rules tab with Destination ID: 2" />
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
