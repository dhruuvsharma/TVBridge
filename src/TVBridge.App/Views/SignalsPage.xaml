<UserControl x:Class="TVBridge.App.Views.SignalsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Signals" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="Live signal log with filtering and replay" Foreground="#888888" FontSize="14" />
        </StackPanel>

        <!-- Filter + Actions -->
        <DockPanel Grid.Row="1" Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="Replay (Dry Run)" Margin="8,0,0,0" Padding="12,6"
                    Command="{Binding ReplayCommand}" />
            <Button DockPanel.Dock="Right" Content="Refresh" Padding="12,6"
                    Command="{Binding LoadCommand}" />
            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Padding="8,6" FontSize="14" Margin="0,0,8,0" />
        </DockPanel>

        <!-- Signals Table -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Signals}"
                  SelectedItem="{Binding SelectedSignal}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="True" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#DDDDDD"
                  RowBackground="White" AlternatingRowBackground="#FAFAFA"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" />
                <DataGridTextColumn Header="Time" Binding="{Binding ReceivedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="140" />
                <DataGridTextColumn Header="Alert" Binding="{Binding AlertId}" Width="100" />
                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="90" />
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="65" />
                <DataGridTextColumn Header="Type" Binding="{Binding OrderType}" Width="65" />
                <DataGridTextColumn Header="Lot" Binding="{Binding LotSize, StringFormat=F2}" Width="55" />
                <DataGridTextColumn Header="Entry" Binding="{Binding EntryPrice, StringFormat=F5}" Width="80" />
                <DataGridTextColumn Header="SL" Binding="{Binding StopLoss, StringFormat=F5}" Width="80" />
                <DataGridTextColumn Header="TP" Binding="{Binding TakeProfit, StringFormat=F5}" Width="80" />
                <DataGridTextColumn Header="Strategy" Binding="{Binding StrategyId}" Width="*" />
                <DataGridCheckBoxColumn Header="OK" Binding="{Binding Processed}" Width="40" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status -->
        <TextBlock Grid.Row="3" Margin="0,8,0,0" FontSize="12" Foreground="#888888">
            <Run Text="{Binding Signals.Count, Mode=OneWay}" />
            <Run Text=" signals shown" />
        </TextBlock>
    </Grid>
</UserControl>
