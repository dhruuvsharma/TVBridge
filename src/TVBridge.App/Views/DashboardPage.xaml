<UserControl x:Class="TVBridge.App.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:TVBridge.App.Converters"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <converters:NullToCollapsedConverter x:Key="NullToCollapsed" />
    </UserControl.Resources>
    <Grid Margin="20" Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <!-- Header + Update Banner -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Dashboard" Style="{DynamicResource PageTitle}" Margin="0,0,0,4" />
            <TextBlock Text="System overview, webhook config, signals, and logs" Style="{DynamicResource PageSubtitle}" />
            <Border Background="{DynamicResource WarningBackground}" CornerRadius="6" Padding="12,8" Margin="0,8,0,0"
                    BorderBrush="{DynamicResource NeonAmber}" BorderThickness="1"
                    Visibility="{Binding UpdateMessage, Converter={StaticResource NullToCollapsed}}">
                <TextBlock Text="{Binding UpdateMessage}" Foreground="{DynamicResource WarningForeground}" FontSize="12" />
            </Border>
        </StackPanel>

        <!-- Row 1: Status Cards + Webhook Config -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <!-- Tunnel Card -->
            <Border Grid.Column="0" Style="{DynamicResource NeonCard}" Margin="0,0,6,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="TUNNEL" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Content="Restart" Style="{DynamicResource NeonButton}"
                                Padding="6,2" FontSize="10" HorizontalAlignment="Right"
                                Command="{Binding RestartTunnelCommand}" />
                    </DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource NeonRed}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TunnelStatus}" Value="Running">
                                            <Setter Property="Fill" Value="{DynamicResource NeonGreen}" />
                                            <Setter Property="Effect" Value="{DynamicResource NeonGlowGreen}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding TunnelStatus}" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock Text="{Binding TunnelUrl}" Foreground="{DynamicResource NeonCyan}" FontSize="9"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding TunnelUrl}" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding TunnelError}" Foreground="{DynamicResource NeonRed}" FontSize="10"
                               TextWrapping="Wrap" ToolTip="{Binding TunnelError}" Margin="0,4,0,0"
                               Visibility="{Binding TunnelError, Converter={StaticResource NullToCollapsed}}" />
                </StackPanel>
            </Border>

            <!-- Signals Count Card -->
            <Border Grid.Column="1" Style="{DynamicResource NeonCard}" Margin="3,0,6,0">
                <StackPanel>
                    <TextBlock Text="SIGNALS" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding SignalCount}" Foreground="{DynamicResource NeonMagenta}" FontSize="24" FontWeight="Bold" />
                </StackPanel>
            </Border>

            <!-- Webhook Config Card -->
            <Border Grid.Column="2" Style="{DynamicResource NeonCard}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="WEBHOOK" Foreground="{DynamicResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,6" />
                    <DockPanel Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Content="Gen" Style="{DynamicResource NeonButton}"
                                Padding="8,4" FontSize="11" Margin="4,0,0,0" Command="{Binding GenerateSecretCommand}" />
                        <TextBox Text="{Binding WebhookSecret, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource NeonTextBox}" FontSize="11" />
                    </DockPanel>
                    <DockPanel>
                        <TextBlock Text="Port:" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <Button DockPanel.Dock="Right" Content="Save" Style="{DynamicResource NeonButtonPrimary}"
                                Padding="8,4" FontSize="11" Margin="4,0,0,0" Command="{Binding SaveWebhookCommand}" />
                        <TextBox Text="{Binding WebhookPort, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource NeonTextBox}" FontSize="11" Width="60" />
                    </DockPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 2: TradingView Template (collapsible) -->
        <Border Grid.Row="2" Style="{DynamicResource NeonCard}" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="TradingView Template" Style="{DynamicResource SectionTitle}" VerticalAlignment="Top" />
                    <Button Content="Regenerate" Style="{DynamicResource NeonButton}" Padding="8,2" FontSize="10"
                            Margin="8,0,0,0" VerticalAlignment="Top" Command="{Binding GenerateTvTemplateCommand}" />
                </StackPanel>
                <TextBox Text="{Binding TvTemplate, Mode=OneWay}" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="10"
                         Background="{DynamicResource SurfaceBrush}"
                         Foreground="{DynamicResource NeonCyan}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="110"
                         VerticalScrollBarVisibility="Auto" Padding="6" />
            </DockPanel>
        </Border>

        <!-- Row 3: Signal Log -->
        <DockPanel Grid.Row="3" Margin="0,0,0,8">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                <TextBlock Text="Signals" Style="{DynamicResource SectionTitle}" VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button DockPanel.Dock="Right" Content="Replay" Style="{DynamicResource NeonButton}"
                        Padding="8,4" FontSize="11" Margin="4,0,0,0" Command="{Binding ReplayCommand}" />
                <Button DockPanel.Dock="Right" Content="Refresh" Style="{DynamicResource NeonButton}"
                        Padding="8,4" FontSize="11" Command="{Binding LoadSignalsCommand}" />
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource NeonTextBox}" FontSize="11" Margin="0,0,4,0" />
            </DockPanel>

            <DataGrid ItemsSource="{Binding RecentSignals}"
                      SelectedItem="{Binding SelectedSignal}"
                      Style="{DynamicResource NeonDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding ReceivedAt, StringFormat=HH:mm:ss}" Width="65" />
                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="75" />
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="55" />
                    <DataGridTextColumn Header="Type" Binding="{Binding OrderType}" Width="55" />
                    <DataGridTextColumn Header="Lot" Binding="{Binding LotSize, StringFormat=F2}" Width="50" />
                    <DataGridTextColumn Header="Entry" Binding="{Binding EntryPrice, StringFormat=F5}" Width="70" />
                    <DataGridTextColumn Header="SL" Binding="{Binding StopLoss, StringFormat=F5}" Width="70" />
                    <DataGridTextColumn Header="TP" Binding="{Binding TakeProfit, StringFormat=F5}" Width="70" />
                    <DataGridTextColumn Header="Strategy" Binding="{Binding StrategyId}" Width="*" />
                    <DataGridCheckBoxColumn Header="OK" Binding="{Binding Processed}" Width="35" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Row 4: Log Viewer Label -->
        <DockPanel Grid.Row="4" Margin="0,0,0,4">
            <TextBlock Text="Application Logs" Style="{DynamicResource SectionTitle}" VerticalAlignment="Center" />
            <Button DockPanel.Dock="Right" Content="Refresh Logs" Style="{DynamicResource NeonButton}"
                    Padding="8,4" FontSize="11" Command="{Binding LoadLogsCommand}" />
        </DockPanel>

        <!-- Row 5: Log Viewer -->
        <Border Grid.Row="5" Style="{DynamicResource NeonCard}" Padding="8">
            <TextBox Text="{Binding LogContent, Mode=OneWay}" IsReadOnly="True"
                     FontFamily="Consolas" FontSize="10"
                     Background="{DynamicResource SurfaceBrush}"
                     Foreground="{DynamicResource NeonGreen}"
                     BorderThickness="0"
                     TextWrapping="NoWrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto" />
        </Border>
    </Grid>
</UserControl>
