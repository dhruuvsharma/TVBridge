<UserControl x:Class="TVBridge.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="24" Background="{DynamicResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Settings" Style="{DynamicResource PageTitle}" Margin="0,0,0,4" />
            <TextBlock Text="Global configuration" Style="{DynamicResource PageSubtitle}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="500" HorizontalAlignment="Left">

                <!-- Trading -->
                <TextBlock Text="Trading" Style="{DynamicResource SectionTitle}" Margin="0,0,0,12" />
                <Border Style="{DynamicResource NeonCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <CheckBox Content="Global Dry-Run Mode (no real orders)" IsChecked="{Binding GlobalDryRun}"
                                  Style="{DynamicResource NeonCheckBox}" FontSize="14" />
                    </StackPanel>
                </Border>

                <!-- Logging -->
                <TextBlock Text="Logging" Style="{DynamicResource SectionTitle}" Margin="0,0,0,12" />
                <Border Style="{DynamicResource NeonCard}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Log Level" Style="{DynamicResource FieldLabel}" />
                        <ComboBox SelectedItem="{Binding LogLevel}" Style="{DynamicResource NeonComboBox}"
                                  Width="180" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Verbose" />
                            <ComboBoxItem Content="Debug" />
                            <ComboBoxItem Content="Information" />
                            <ComboBoxItem Content="Warning" />
                            <ComboBoxItem Content="Error" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Save -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="Save Settings" Style="{DynamicResource NeonButtonPrimary}"
                            Command="{Binding SaveCommand}" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource NeonGreen}"
                               VerticalAlignment="Center" Margin="12,0,0,0" FontSize="12" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
