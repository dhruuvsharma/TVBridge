<UserControl x:Class="TVBridge.App.Views.RulesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="24" Background="{DynamicResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- Rules List -->
        <DockPanel Grid.Column="0" Margin="0,0,16,0">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="Routing Rules" Style="{DynamicResource PageTitle}" Margin="0,0,0,4" />
                <TextBlock Text="Route signals to channels based on match conditions" Style="{DynamicResource PageSubtitle}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Move Up" Style="{DynamicResource NeonButton}" Margin="0,0,6,0"
                        Command="{Binding MoveUpCommand}" />
                <Button Content="Move Down" Style="{DynamicResource NeonButton}" Margin="0,0,6,0"
                        Command="{Binding MoveDownCommand}" />
                <Button Content="Delete" Style="{DynamicResource NeonButton}" Foreground="{DynamicResource NeonRed}"
                        Command="{Binding DeleteRuleCommand}" />
            </StackPanel>

            <DataGrid ItemsSource="{Binding Rules}"
                      SelectedItem="{Binding SelectedRule}"
                      Style="{DynamicResource NeonDataGrid}"
                      CanUserSortColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Priority}" Width="35" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="75" />
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="60" />
                    <DataGridTextColumn Header="Strategy" Binding="{Binding StrategyId}" Width="85" />
                    <DataGridTextColumn Header="Dest" Binding="{Binding DestinationIds}" Width="55" />
                    <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="35" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Edit Panel -->
        <Border Grid.Column="1" Style="{DynamicResource NeonCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Rule Editor" Style="{DynamicResource SectionTitle}" Margin="0,0,0,14" />

                    <TextBlock Text="Name *" Style="{DynamicResource FieldLabel}" />
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource NeonTextBox}" Margin="0,0,0,10" />

                    <TextBlock Text="Strategy ID (blank = any)" Style="{DynamicResource FieldLabel}" />
                    <TextBox Text="{Binding EditStrategyId, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource NeonTextBox}" Margin="0,0,0,10" />

                    <TextBlock Text="Symbol (blank = any)" Style="{DynamicResource FieldLabel}" />
                    <TextBox Text="{Binding EditSymbol, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource NeonTextBox}" Margin="0,0,0,10" />

                    <TextBlock Text="Action (blank = any)" Style="{DynamicResource FieldLabel}" />
                    <TextBox Text="{Binding EditAction, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource NeonTextBox}" Margin="0,0,0,10" />

                    <TextBlock Text="Account Tag (blank = any)" Style="{DynamicResource FieldLabel}" />
                    <TextBox Text="{Binding EditAccountTag, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource NeonTextBox}" Margin="0,0,0,10" />

                    <TextBlock Text="Timeframe (blank = any)" Style="{DynamicResource FieldLabel}" />
                    <TextBox Text="{Binding EditTimeframe, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource NeonTextBox}" Margin="0,0,0,10" />

                    <TextBlock Text="Destination IDs (comma-separated)" Style="{DynamicResource FieldLabel}" />
                    <TextBox Text="{Binding EditDestinationIds, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource NeonTextBox}" Margin="0,0,0,10" />

                    <TextBlock Text="Priority" Style="{DynamicResource FieldLabel}" />
                    <TextBox Text="{Binding EditPriority, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource NeonTextBox}" Margin="0,0,0,10" />

                    <CheckBox Content="Continue on match" IsChecked="{Binding EditContinueOnMatch}"
                              Style="{DynamicResource NeonCheckBox}" Margin="0,0,0,8" />
                    <CheckBox Content="Enabled" IsChecked="{Binding EditEnabled}"
                              Style="{DynamicResource NeonCheckBox}" Margin="0,0,0,14" />

                    <Button Content="Save Rule" Style="{DynamicResource NeonButtonPrimary}"
                            Command="{Binding SaveRuleCommand}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
