<UserControl x:Class="TVBridge.App.Views.RulesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Rules List -->
        <DockPanel Grid.Column="0" Margin="0,0,16,0">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="Rules" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock Text="Route signals to channels based on match conditions" Foreground="#888888" FontSize="14" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Move Up" Padding="8,4" Margin="0,0,4,0" Command="{Binding MoveUpCommand}" />
                <Button Content="Move Down" Padding="8,4" Margin="0,0,4,0" Command="{Binding MoveDownCommand}" />
                <Button Content="Delete" Padding="8,4" Foreground="Red" Command="{Binding DeleteRuleCommand}" />
            </StackPanel>

            <DataGrid ItemsSource="{Binding Rules}"
                      SelectedItem="{Binding SelectedRule}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserSortColumns="False" HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#DDDDDD"
                      RowBackground="White" AlternatingRowBackground="#FAFAFA"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Priority}" Width="35" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="80" />
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="65" />
                    <DataGridTextColumn Header="Strategy" Binding="{Binding StrategyId}" Width="90" />
                    <DataGridTextColumn Header="Dest" Binding="{Binding DestinationIds}" Width="60" />
                    <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled}" Width="35" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Edit Panel -->
        <Border Grid.Column="1" Background="#F8F8FC" CornerRadius="8" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Rule Editor" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <TextBlock Text="Name *" FontSize="12" Foreground="#666666" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <TextBlock Text="Strategy ID (blank = any)" FontSize="12" Foreground="#666666" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditStrategyId, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <TextBlock Text="Symbol (blank = any)" FontSize="12" Foreground="#666666" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditSymbol, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <TextBlock Text="Action (blank = any)" FontSize="12" Foreground="#666666" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditAction, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <TextBlock Text="Account Tag (blank = any)" FontSize="12" Foreground="#666666" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditAccountTag, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <TextBlock Text="Timeframe (blank = any)" FontSize="12" Foreground="#666666" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditTimeframe, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <TextBlock Text="Destination IDs (comma-separated)" FontSize="12" Foreground="#666666" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditDestinationIds, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <TextBlock Text="Priority" FontSize="12" Foreground="#666666" Margin="0,0,0,4" />
                    <TextBox Text="{Binding EditPriority, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,0,0,10" />

                    <CheckBox Content="Continue on match" IsChecked="{Binding EditContinueOnMatch}" Margin="0,0,0,8" />
                    <CheckBox Content="Enabled" IsChecked="{Binding EditEnabled}" Margin="0,0,0,16" />

                    <Button Content="Save Rule" Padding="12,8" FontWeight="SemiBold"
                            Background="#2D2D44" Foreground="White" BorderThickness="0"
                            Command="{Binding SaveRuleCommand}" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
