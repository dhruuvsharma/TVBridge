<UserControl x:Class="TVBridge.App.Views.ChannelsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Channels" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
            <TextBlock Text="Configure output channels and test connectivity" Foreground="#888888" FontSize="14" />
        </StackPanel>

        <!-- Channels List -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Channels}"
                  SelectedItem="{Binding SelectedChannel}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserSortColumns="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#DDDDDD"
                  RowBackground="White" AlternatingRowBackground="#FAFAFA"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Type" Binding="{Binding ChannelType}" Width="120" />
                <DataGridTextColumn Header="ID" Binding="{Binding ChannelId}" Width="50" />
                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Actions -->
        <Border Grid.Row="2" Margin="0,12,0,0" Padding="0,8,0,0" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Content="Toggle Enable" Padding="12,6" Margin="0,0,8,0"
                            Command="{Binding ToggleEnabledCommand}" />
                    <Button Content="Validate Config" Padding="12,6" Margin="0,0,8,0"
                            Command="{Binding ValidateCommand}" />
                    <Button Content="Test Send (Dry Run)" Padding="12,6"
                            Command="{Binding TestSendCommand}" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding TestResult}"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="#666666" FontSize="12" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
