             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <StackPanel VerticalAlignment="Top">
            <TextBlock Text="Channels" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
