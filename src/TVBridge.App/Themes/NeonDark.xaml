<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vsRk="clr-namespace:AvalonDock.Themes.VS2013.Themes;assembly=AvalonDock.Themes.VS2013">

    <!--
        Monochrome Dark theme.
        Brush keys retain their original "Neon*" names for backward compatibility
        with existing page XAML — only the color values are now grayscale.
    -->

    <!-- Background -->
    <SolidColorBrush x:Key="AppBackground" Color="#0A0A0A" />
    <SolidColorBrush x:Key="SidebarBackground" Color="#111111" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#161616" />
    <SolidColorBrush x:Key="Surface2Brush" Color="#1F1F1F" />
    <SolidColorBrush x:Key="StatusBarBackground" Color="#111111" />

    <!-- Accent (monochrome — was neon) -->
    <SolidColorBrush x:Key="NeonCyan" Color="#FFFFFF" />
    <SolidColorBrush x:Key="NeonMagenta" Color="#BBBBBB" />
    <SolidColorBrush x:Key="NeonGreen" Color="#FFFFFF" />
    <SolidColorBrush x:Key="NeonAmber" Color="#BBBBBB" />
    <SolidColorBrush x:Key="NeonRed" Color="#FFFFFF" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FFFFFF" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
    <SolidColorBrush x:Key="TextSecondary" Color="#A8A8A8" />
    <SolidColorBrush x:Key="TextMuted" Color="#6E6E6E" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#2A2A2A" />
    <SolidColorBrush x:Key="BorderHover" Color="#FFFFFF" />

    <!-- Nav -->
    <SolidColorBrush x:Key="NavHoverBackground" Color="#1F1F1F" />
    <SolidColorBrush x:Key="NavActiveBackground" Color="#181818" />
    <SolidColorBrush x:Key="NavActiveBorder" Color="#FFFFFF" />
    <SolidColorBrush x:Key="NavText" Color="#A8A8A8" />
    <SolidColorBrush x:Key="NavActiveText" Color="#FFFFFF" />

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackground" Color="#1F1F1F" />
    <SolidColorBrush x:Key="ButtonHoverBackground" Color="#2D2D2D" />
    <SolidColorBrush x:Key="ButtonForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ButtonPrimaryBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ButtonPrimaryForeground" Color="#000000" />

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackground" Color="#161616" />
    <SolidColorBrush x:Key="InputBorder" Color="#2A2A2A" />
    <SolidColorBrush x:Key="InputFocusBorder" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputForeground" Color="#FFFFFF" />

    <!-- DataGrid -->
    <SolidColorBrush x:Key="GridRowBackground" Color="#121212" />
    <SolidColorBrush x:Key="GridAltRowBackground" Color="#181818" />
    <SolidColorBrush x:Key="GridHeaderBackground" Color="#1F1F1F" />
    <SolidColorBrush x:Key="GridHeaderForeground" Color="#A8A8A8" />
    <SolidColorBrush x:Key="GridSelectedBackground" Color="#2D2D2D" />
    <SolidColorBrush x:Key="GridLineBrush" Color="#222222" />

    <!-- Cards -->
    <SolidColorBrush x:Key="CardBackground" Color="#161616" />
    <SolidColorBrush x:Key="CardBorder" Color="#2A2A2A" />

    <!-- Menu / Popup -->
    <SolidColorBrush x:Key="MenuBackground" Color="#111111" />
    <SolidColorBrush x:Key="MenuItemHoverBackground" Color="#2D2D2D" />
    <SolidColorBrush x:Key="SubmenuBackground" Color="#181818" />
    <SolidColorBrush x:Key="SubmenuBorder" Color="#2A2A2A" />

    <!-- Status (monochrome — bg shading carries semantics) -->
    <SolidColorBrush x:Key="SuccessBackground" Color="#1A1A1A" />
    <SolidColorBrush x:Key="SuccessForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="WarningBackground" Color="#1A1A1A" />
    <SolidColorBrush x:Key="WarningForeground" Color="#BBBBBB" />
    <SolidColorBrush x:Key="ErrorBackground" Color="#252525" />
    <SolidColorBrush x:Key="ErrorForeground" Color="#FFFFFF" />

    <!-- Glow effects neutralised (kept as keys so page XAML still resolves) -->
    <DropShadowEffect x:Key="NeonGlow" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="NeonGlowMagenta" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="NeonGlowGreen" Color="#000000" BlurRadius="0" ShadowDepth="0" Opacity="0" />
    <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="16" ShadowDepth="2" Opacity="0.5" />

    <!-- Corner Radius -->
    <CornerRadius x:Key="CardRadius">8</CornerRadius>
    <CornerRadius x:Key="ButtonRadius">6</CornerRadius>
    <CornerRadius x:Key="InputRadius">4</CornerRadius>

    <!-- ===== CONTROL STYLES ===== -->

    <!-- NavButton -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource NavText}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavHoverBackground}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NeonButton (default) -->
    <Style x:Key="NeonButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ButtonBackground}" />
        <Setter Property="Foreground" Value="{StaticResource ButtonForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ButtonRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonHoverBackground}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NeonButtonPrimary -->
    <Style x:Key="NeonButtonPrimary" TargetType="Button" BasedOn="{StaticResource NeonButton}">
        <Setter Property="Background" Value="{StaticResource ButtonPrimaryBackground}" />
        <Setter Property="Foreground" Value="{StaticResource ButtonPrimaryForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource ButtonPrimaryBackground}" />
    </Style>

    <!-- NeonTextBox -->
    <Style x:Key="NeonTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource InputBackground}" />
        <Setter Property="Foreground" Value="{StaticResource InputForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource InputFocusBorder}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- NeonCheckBox -->
    <Style x:Key="NeonCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- NeonComboBox -->
    <Style x:Key="NeonComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource InputBackground}" />
        <Setter Property="Foreground" Value="{StaticResource InputForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- NeonCard -->
    <Style x:Key="NeonCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CardRadius}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <!-- DataGrid Column Header (global, not keyed — applies inside NeonDataGrid) -->
    <Style x:Key="NeonColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource GridHeaderBackground}" />
        <Setter Property="Foreground" Value="{StaticResource GridHeaderForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- DataGrid Row -->
    <Style x:Key="NeonDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource GridRowBackground}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource GridSelectedBackground}" />
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface2Brush}" />
            </Trigger>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{StaticResource GridAltRowBackground}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DataGrid Cell -->
    <Style x:Key="NeonDataGridCell" TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- NeonDataGrid -->
    <Style x:Key="NeonDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="{StaticResource GridRowBackground}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource GridAltRowBackground}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource NeonColumnHeader}" />
        <Setter Property="RowStyle" Value="{StaticResource NeonDataGridRow}" />
        <Setter Property="CellStyle" Value="{StaticResource NeonDataGridCell}" />
    </Style>

    <!-- Page title -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PageSubtitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- ===== MENU / CONTEXT MENU (implicit, theme-wide) ===== -->

    <!-- Top-level Menu bar -->
    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource MenuBackground}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Separator inside menu popups -->
    <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Rectangle Height="1" Fill="{StaticResource BorderBrush}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MenuItem: top-level header (e.g. "View" in the menu bar) -->
    <ControlTemplate x:Key="TopLevelMenuItemTemplate" TargetType="MenuItem">
        <Border x:Name="Bd"
                Background="{TemplateBinding Background}"
                BorderThickness="0"
                Padding="{TemplateBinding Padding}">
            <Grid>
                <ContentPresenter ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center" />
                <Popup x:Name="PART_Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="None">
                    <Border Background="{StaticResource SubmenuBackground}"
                            BorderBrush="{StaticResource SubmenuBorder}"
                            BorderThickness="1"
                            Padding="2"
                            MinWidth="160">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </Popup>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource MenuItemHoverBackground}" />
            </Trigger>
            <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource MenuItemHoverBackground}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- MenuItem: submenu item (rows inside the dropdown) -->
    <ControlTemplate x:Key="SubmenuMenuItemTemplate" TargetType="MenuItem">
        <Border x:Name="Bd"
                Background="{TemplateBinding Background}"
                BorderThickness="0"
                Padding="0">
            <Grid MinHeight="26">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="14" />
                </Grid.ColumnDefinitions>
                <Path x:Name="Check" Grid.Column="0"
                      Visibility="Collapsed"
                      Width="10" Height="10"
                      Stretch="Uniform"
                      Stroke="{StaticResource TextPrimary}"
                      StrokeThickness="1.6"
                      Data="M 0,5 L 4,9 L 10,0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
                <ContentPresenter Grid.Column="1"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center"
                                  Margin="4,0,12,0" />
                <TextBlock Grid.Column="2"
                           Text="{TemplateBinding InputGestureText}"
                           Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" />
                <Path x:Name="Arrow" Grid.Column="3"
                      Visibility="Collapsed"
                      Width="6" Height="8"
                      Fill="{StaticResource TextSecondary}"
                      Data="M 0,0 L 4,4 L 0,8 Z"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
                <Popup x:Name="PART_Popup"
                       Placement="Right"
                       HorizontalOffset="-2"
                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="None">
                    <Border Background="{StaticResource SubmenuBackground}"
                            BorderBrush="{StaticResource SubmenuBorder}"
                            BorderThickness="1"
                            Padding="2"
                            MinWidth="160">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </Popup>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource MenuItemHoverBackground}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="10,4" />
        <Style.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="Template" Value="{StaticResource TopLevelMenuItemTemplate}" />
            </Trigger>
            <Trigger Property="Role" Value="TopLevelItem">
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="Template" Value="{StaticResource TopLevelMenuItemTemplate}" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter Property="Template" Value="{StaticResource SubmenuMenuItemTemplate}" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuItem">
                <Setter Property="Template" Value="{StaticResource SubmenuMenuItemTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ContextMenu (used by AvalonDock tab right-click) -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource SubmenuBackground}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource SubmenuBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="HasDropShadow" Value="False" />
    </Style>

    <!-- ===== AvalonDock VS2013 theme overrides (monochrome dark) ===== -->
    <Color x:Key="{x:Static vsRk:ResourceKeys.ControlAccentColorKey}">#FFFFFFFF</Color>
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ControlAccentBrushKey}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.Background}" Color="#0A0A0A" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.PanelBorderBrush}" Color="Transparent" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.TabBackground}" Color="#0A0A0A" />

    <!-- Tool window caption (pin/close button bar) -->
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionActiveBackground}" Color="#1F1F1F" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionActiveText}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionActiveGrip}" Color="#A8A8A8" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionInactiveBackground}" Color="#161616" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionInactiveText}" Color="#A8A8A8" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionInactiveGrip}" Color="#6E6E6E" />

    <!-- Caption buttons (pin / hide / close) -->
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonActiveGlyph}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonActiveHoveredBackground}" Color="#2D2D2D" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonActiveHoveredBorder}" Color="Transparent" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonActiveHoveredGlyph}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonActivePressedBackground}" Color="#3D3D3D" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonActivePressedBorder}" Color="Transparent" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonActivePressedGlyph}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonInactiveGlyph}" Color="#A8A8A8" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredBackground}" Color="#2D2D2D" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredBorder}" Color="Transparent" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonInactiveHoveredGlyph}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonInactivePressedBackground}" Color="#3D3D3D" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonInactivePressedBorder}" Color="Transparent" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowCaptionButtonInactivePressedGlyph}" Color="#FFFFFF" />

    <!-- Tool window tabs -->
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowTabSelectedActiveBackground}" Color="#0A0A0A" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowTabSelectedActiveText}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowTabSelectedInactiveBackground}" Color="#0A0A0A" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowTabSelectedInactiveText}" Color="#A8A8A8" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowTabUnselectedBackground}" Color="#0A0A0A" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowTabUnselectedText}" Color="#A8A8A8" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowTabUnselectedHoveredBackground}" Color="#1F1F1F" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.ToolWindowTabUnselectedHoveredText}" Color="#FFFFFF" />

    <!-- Document well tabs (rarely used here, but covered for consistency) -->
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.DocumentWellTabSelectedActiveBackground}" Color="#1F1F1F" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.DocumentWellTabSelectedActiveText}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.DocumentWellTabSelectedInactiveBackground}" Color="#161616" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.DocumentWellTabSelectedInactiveText}" Color="#A8A8A8" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.DocumentWellTabUnselectedBackground}" Color="#0A0A0A" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.DocumentWellTabUnselectedText}" Color="#A8A8A8" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.DocumentWellTabUnselectedHoveredBackground}" Color="#1F1F1F" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.DocumentWellTabUnselectedHoveredText}" Color="#FFFFFF" />

    <!-- Floating windows -->
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.FloatingDocumentWindowBackground}" Color="#0A0A0A" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.FloatingDocumentWindowBorder}" Color="#2A2A2A" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.FloatingToolWindowBackground}" Color="#0A0A0A" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.FloatingToolWindowBorder}" Color="#2A2A2A" />

    <!-- Navigator (Ctrl+Tab popup) -->
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.NavigatorWindowBackground}" Color="#161616" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.NavigatorWindowForeground}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.NavigatorWindowSelectedBackground}" Color="#2D2D2D" />
    <SolidColorBrush x:Key="{x:Static vsRk:ResourceKeys.NavigatorWindowSelectedText}" Color="#FFFFFF" />

</ResourceDictionary>
