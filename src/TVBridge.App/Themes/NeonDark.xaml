<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <SolidColorBrush x:Key="AppBackground" Color="#0A0A1A" />
    <SolidColorBrush x:Key="SidebarBackground" Color="#0D0D22" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#141428" />
    <SolidColorBrush x:Key="Surface2Brush" Color="#1E1E3A" />
    <SolidColorBrush x:Key="StatusBarBackground" Color="#0D0D22" />

    <!-- Accent / Neon -->
    <SolidColorBrush x:Key="NeonCyan" Color="#00F0FF" />
    <SolidColorBrush x:Key="NeonMagenta" Color="#FF00FF" />
    <SolidColorBrush x:Key="NeonGreen" Color="#00FF88" />
    <SolidColorBrush x:Key="NeonAmber" Color="#FFB800" />
    <SolidColorBrush x:Key="NeonRed" Color="#FF3366" />
    <SolidColorBrush x:Key="AccentBrush" Color="#00F0FF" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#E0E0FF" />
    <SolidColorBrush x:Key="TextSecondary" Color="#8888AA" />
    <SolidColorBrush x:Key="TextMuted" Color="#555577" />

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#2A2A4A" />
    <SolidColorBrush x:Key="BorderHover" Color="#00F0FF" />

    <!-- Nav -->
    <SolidColorBrush x:Key="NavHoverBackground" Color="#1A1A3A" />
    <SolidColorBrush x:Key="NavActiveBackground" Color="#141438" />
    <SolidColorBrush x:Key="NavActiveBorder" Color="#00F0FF" />
    <SolidColorBrush x:Key="NavText" Color="#8888AA" />
    <SolidColorBrush x:Key="NavActiveText" Color="#00F0FF" />

    <!-- Buttons -->
    <SolidColorBrush x:Key="ButtonBackground" Color="#1E1E3A" />
    <SolidColorBrush x:Key="ButtonHoverBackground" Color="#2A2A50" />
    <SolidColorBrush x:Key="ButtonForeground" Color="#00F0FF" />
    <SolidColorBrush x:Key="ButtonPrimaryBackground" Color="#00F0FF" />
    <SolidColorBrush x:Key="ButtonPrimaryForeground" Color="#0A0A1A" />

    <!-- Input -->
    <SolidColorBrush x:Key="InputBackground" Color="#141428" />
    <SolidColorBrush x:Key="InputBorder" Color="#2A2A4A" />
    <SolidColorBrush x:Key="InputFocusBorder" Color="#00F0FF" />
    <SolidColorBrush x:Key="InputForeground" Color="#E0E0FF" />

    <!-- DataGrid -->
    <SolidColorBrush x:Key="GridRowBackground" Color="#0F0F22" />
    <SolidColorBrush x:Key="GridAltRowBackground" Color="#141428" />
    <SolidColorBrush x:Key="GridHeaderBackground" Color="#1A1A35" />
    <SolidColorBrush x:Key="GridHeaderForeground" Color="#8888AA" />
    <SolidColorBrush x:Key="GridSelectedBackground" Color="#1A2A4A" />
    <SolidColorBrush x:Key="GridLineBrush" Color="#1E1E3A" />

    <!-- Cards -->
    <SolidColorBrush x:Key="CardBackground" Color="#141428" />
    <SolidColorBrush x:Key="CardBorder" Color="#2A2A4A" />

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBackground" Color="#0A1A14" />
    <SolidColorBrush x:Key="SuccessForeground" Color="#00FF88" />
    <SolidColorBrush x:Key="WarningBackground" Color="#1A1508" />
    <SolidColorBrush x:Key="WarningForeground" Color="#FFB800" />
    <SolidColorBrush x:Key="ErrorBackground" Color="#1A0A12" />
    <SolidColorBrush x:Key="ErrorForeground" Color="#FF3366" />

    <!-- Glow Effects -->
    <DropShadowEffect x:Key="NeonGlow" Color="#00F0FF" BlurRadius="12" ShadowDepth="0" Opacity="0.5" />
    <DropShadowEffect x:Key="NeonGlowMagenta" Color="#FF00FF" BlurRadius="12" ShadowDepth="0" Opacity="0.5" />
    <DropShadowEffect x:Key="NeonGlowGreen" Color="#00FF88" BlurRadius="12" ShadowDepth="0" Opacity="0.5" />
    <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="16" ShadowDepth="2" Opacity="0.4" />

    <!-- Corner Radius -->
    <CornerRadius x:Key="CardRadius">8</CornerRadius>
    <CornerRadius x:Key="ButtonRadius">6</CornerRadius>
    <CornerRadius x:Key="InputRadius">4</CornerRadius>

    <!-- ===== CONTROL STYLES ===== -->

    <!-- NavButton -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource NavText}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavHoverBackground}" />
                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NeonButton (default) -->
    <Style x:Key="NeonButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ButtonBackground}" />
        <Setter Property="Foreground" Value="{StaticResource ButtonForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource ButtonRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonHoverBackground}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- NeonButtonPrimary -->
    <Style x:Key="NeonButtonPrimary" TargetType="Button" BasedOn="{StaticResource NeonButton}">
        <Setter Property="Background" Value="{StaticResource ButtonPrimaryBackground}" />
        <Setter Property="Foreground" Value="{StaticResource ButtonPrimaryForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource ButtonPrimaryBackground}" />
    </Style>

    <!-- NeonTextBox -->
    <Style x:Key="NeonTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource InputBackground}" />
        <Setter Property="Foreground" Value="{StaticResource InputForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource InputFocusBorder}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- NeonCheckBox -->
    <Style x:Key="NeonCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- NeonComboBox -->
    <Style x:Key="NeonComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource InputBackground}" />
        <Setter Property="Foreground" Value="{StaticResource InputForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- NeonCard -->
    <Style x:Key="NeonCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackground}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CardRadius}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <!-- DataGrid Column Header (global, not keyed — applies inside NeonDataGrid) -->
    <Style x:Key="NeonColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource GridHeaderBackground}" />
        <Setter Property="Foreground" Value="{StaticResource GridHeaderForeground}" />
        <Setter Property="BorderBrush" Value="{StaticResource GridLineBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <!-- DataGrid Row -->
    <Style x:Key="NeonDataGridRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource GridRowBackground}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource GridSelectedBackground}" />
                <Setter Property="Foreground" Value="{StaticResource NeonCyan}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Surface2Brush}" />
            </Trigger>
            <Trigger Property="AlternationIndex" Value="1">
                <Setter Property="Background" Value="{StaticResource GridAltRowBackground}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DataGrid Cell -->
    <Style x:Key="NeonDataGridCell" TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource NeonCyan}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- NeonDataGrid -->
    <Style x:Key="NeonDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="{StaticResource GridRowBackground}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource GridAltRowBackground}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource GridLineBrush}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource NeonColumnHeader}" />
        <Setter Property="RowStyle" Value="{StaticResource NeonDataGridRow}" />
        <Setter Property="CellStyle" Value="{StaticResource NeonDataGridCell}" />
    </Style>

    <!-- Page title -->
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PageSubtitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource NeonCyan}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

</ResourceDictionary>
