<Window x:Class="TVBridge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TVBridge.App.Views"
        Title="TVBridge" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A5C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.RowSpan="2" Background="#2D2D44">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="TVBridge"
                           Foreground="White" FontSize="20" FontWeight="Bold"
                           Margin="16,20,16,24" />

                <StackPanel>
                    <Button Content="Dashboard" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Dashboard" />
                    <Button Content="Signals" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Signals" />
                    <Button Content="Rules" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Rules" />
                    <Button Content="Channels" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Channels" />
                    <Button Content="Settings" Style="{StaticResource NavButton}"
                            Command="{Binding NavigateToCommand}" CommandParameter="Settings" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Grid.Row="0" Margin="0">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedPage}" Value="Dashboard">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <views:DashboardPage />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedPage}" Value="Signals">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <views:SignalsPage />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedPage}" Value="Rules">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <views:RulesPage />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedPage}" Value="Channels">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <views:ChannelsPage />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SelectedPage}" Value="Settings">
                            <Setter Property="Content">
                                <Setter.Value>
                                    <views:SettingsPage />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <!-- Status Bar -->
        <Border Grid.Column="1" Grid.Row="1" Background="#F0F0F0" Padding="12,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Margin="12,0,0,0" FontSize="12" Foreground="#4488CC"
                           Text="{Binding TunnelUrl}" ToolTip="Click to copy tunnel URL"
                           Cursor="Hand" MouseLeftButtonDown="CopyTunnelUrl_Click"
                           Visibility="{Binding TunnelUrl, Converter={StaticResource NullToCollapsed}}" />
                <TextBlock Text="{Binding TunnelStatusText}" FontSize="12" Foreground="#666666" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
